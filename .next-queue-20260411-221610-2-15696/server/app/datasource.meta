{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/datasource/layout,_N_T_/datasource/page,_N_T_/datasource"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/datasource/__PAGE__",
    "/datasource",
    "/_index",
    "/_head"
  ]
}